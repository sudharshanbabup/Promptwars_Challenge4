{
  "name": "varshamitra",
  "version": "1.0.0",
  "description": "GenAI monsoon preparedness & citizen assistance assistant",
  "main": "dist/server/index.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && esbuild src/server/index.ts --bundle --platform=node --target=node20 --format=esm --outfile=dist/server/index.js --external:express --external:helmet --external:compression --external:express-rate-limit --external:@google/genai --external:fs --external:path --external:url",
    "start": "node dist/server/index.js",
    "test": "node --import tsx --test tests/**/*.test.ts",
    "test:coverage": "node --import tsx --experimental-test-coverage --test tests/**/*.test.ts",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^0.11.0",
    "compression": "^1.7.4",
    "express": "^4.19.2",
    "express-rate-limit": "^7.2.0",
    "helmet": "^7.1.0",
    "lucide-react": "^0.395.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "esbuild": "^0.28.1",
    "tsx": "^4.15.1",
    "typescript": "^5.4.5",
    "vite": "^5.2.11"
  }
}
